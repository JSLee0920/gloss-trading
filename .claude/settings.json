{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm -C web install)",
      "Bash(pnpm -C web dev:*)",
      "Bash(pnpm -C web build)",
      "Bash(pnpm -C web lint:*)",
      "Bash(pnpm -C web typecheck)",
      "Bash(pnpm -C web test:*)",
      "Bash(pnpm -C web exec tsc:*)",
      "Bash(pnpm -C web e2e:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/verify-typecheck.sh\"",
            "timeout": 60,
            "statusMessage": "Typechecking web/…"
          }
        ]
      }
    ]
  }
}
